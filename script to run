local cachedBall = nil
local lastScan = 0

local function GetBall()
    if cachedBall and cachedBall.Parent and cachedBall:IsA("BasePart") then
        return cachedBall
    end
    
    local now = os.clock()
    if now - lastScan < 0.5 then
        return nil
    end
    lastScan = now
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:lower() == "ball" or obj.Name:lower():find("football") or obj.Name:lower():find("soccer")) then
            cachedBall = obj
            return obj
        end
    end
    
    local fallback = Workspace:FindFirstChild("Ball")
    if fallback and fallback:IsA("BasePart") then
        cachedBall = fallback
        return fallback
    end
    
    return nil
end

local function IsBallHeld(ball)
    if not ball then return false end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root and (ball.Position - root.Position).Magnitude < 3.5 then
                return true
            end
        end
    end
    if ball:FindFirstChildOfClass("Weld") or ball:FindFirstChildOfClass("WeldConstraint") or ball:FindFirstChildOfClass("Motor6D") then
        return true
    end
    return false
end

-- Hàm kiểm tra Team trên Leaderboard
local function GetPlayerTeamName()
    if LocalPlayer.Team then
        return LocalPlayer.Team.Name:lower()
    end
    
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats") or LocalPlayer:FindFirstChild("Data")
    if leaderstats then
        local teamValue = leaderstats:FindFirstChild("Team") or leaderstats:FindFirstChild("Side")
        if teamValue then
            return tostring(teamValue.Value):lower()
        end
    end
    return ""
end

task.spawn(function()
    while not _G.StopBallControlLoop do
        RunService.Heartbeat:Wait() 
        local ball = GetBall()
        local character = LocalPlayer.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        
        if ball and root then
            if cameraLocked then
                Camera.CameraType = Enum.CameraType.Custom
                if Camera.CameraSubject ~= ball then
                    Camera.CameraSubject = ball
                end
            end

            local heldByOther = IsBallHeld(ball)

            if autoMagnet and not heldByOther then
                pcall(function()
                    ball.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    ball.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    ball.CFrame = root.CFrame * CFrame.new(0, 0, -3)
                end)
                
                if firetouchinterest then
                    local leg = character:FindFirstChild("Left Leg") or character:FindFirstChild("Right Leg") or character:FindFirstChild("LeftLowerLeg") or character:FindFirstChild("RightLowerLeg") or root
                    if leg then
                        firetouchinterest(leg, ball, 0)
                        firetouchinterest(leg, ball, 1)
                    end
                end
                task.wait(0.05)
            elseif isPressing and currentDirection ~= Vector3.new(0,0,0) and not heldByOther then
                local camCFrame = Camera.CFrame
                local moveVector = Vector3.new(0,0,0)
                if currentDirection.Z ~= 0 then moveVector = moveVector + (camCFrame.LookVector * -currentDirection.Z) end
                if currentDirection.X ~= 0 then moveVector = moveVector + (camCFrame.RightVector * currentDirection.X) end
                if currentDirection.Y ~= 0 then moveVector = moveVector + Vector3.new(0, currentDirection.Y, 0) end

                if moveVector.Magnitude > 0 then
                    pcall(function()
                        ball.AssemblyLinearVelocity = moveVector.Unit * (currentSpeed * 25)
                    end)
                end
            end
        else
            if cameraLocked and character and character:FindFirstChild("Humanoid") then
                cameraLocked = false
                Camera.CameraSubject = character.Humanoid
            end
        end
    end
end)

local function createDriveButton(text, pos, dirVec)
    local btn = Instance.new("TextButton")
