local cachedBall = nil
local lastScan = 0

local function GetBall()
    if cachedBall and cachedBall.Parent and cachedBall:IsA("BasePart") then
        return cachedBall
    end
    
    local now = os.clock()
    if now - lastScan < 0.5 then
        return nil
    end
    lastScan = now
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:lower() == "ball" or obj.Name:lower():find("football") or obj.Name:lower():find("soccer")) then
            cachedBall = obj
            return obj
        end
    end
    
    local fallback = Workspace:FindFirstChild("Ball")
    if fallback and fallback:IsA("BasePart") then
        cachedBall = fallback
        return fallback
    end
    
    return nil
end

local function GetPlayerByName(nameText)
    if not nameText or nameText == "" then return nil end
    nameText = nameText:lower()
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local nameMatch = p.Name:lower():find(nameText, 1, true)
            local displayNameMatch = p.DisplayName:lower():find(nameText, 1, true)
            if nameMatch or displayNameMatch then
                return p
            end
        end
    end
    return nil
end

local function IsBallHeld(ball)
    if not ball then return false end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root and (ball.Position - root.Position).Magnitude < 3.5 then
                return true
            end
        end
    end
    if ball:FindFirstChildOfClass("Weld") or ball:FindFirstChildOfClass("WeldConstraint") or ball:FindFirstChildOfClass("Motor6D") then
        return true
    end
    return false
end

