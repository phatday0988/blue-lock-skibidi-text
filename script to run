local PlayerNameInput = Instance.new("TextBox")

task.spawn(function()
    while not _G.StopBallControlLoop do
        RunService.Heartbeat:Wait() 
        local ball = GetBall()
        local character = LocalPlayer.Character
        local root = character and character:FindFirstChild("HumanoidRootPart")
        
        if ball and root then
            if cameraLocked then
                Camera.CameraType = Enum.CameraType.Custom
                if Camera.CameraSubject ~= ball then
                    Camera.CameraSubject = ball
                end
            end

            local heldByOther = IsBallHeld(ball)

            if autoMagnet and not heldByOther then
                pcall(function()
                    ball.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    ball.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    ball.CFrame = root.CFrame * CFrame.new(0, 0, -3)
                end)
                
                if firetouchinterest then
                    local leg = character:FindFirstChild("Left Leg") or character:FindFirstChild("Right Leg") or character:FindFirstChild("LeftLowerLeg") or character:FindFirstChild("RightLowerLeg") or root
                    if leg then
                        firetouchinterest(leg, ball, 0)
                        firetouchinterest(leg, ball, 1)
                    end
                end
                task.wait(0.05)
            elseif autoPass and not heldByOther then
                -- Vòng lặp Auto Pass
                local targetPlayer = GetPlayerByName(PlayerNameInput.Text)
                if targetPlayer and targetPlayer.Character then
                    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if targetRoot then
                        pcall(function()
                            local passDirection = (targetRoot.Position - ball.Position).Unit
                            ball.AssemblyLinearVelocity = passDirection * (currentSpeed * 35)
                        end)
                    end
                end
            elseif isPressing and currentDirection ~= Vector3.new(0,0,0) and not heldByOther then
                local camCFrame = Camera.CFrame
                local moveVector = Vector3.new(0,0,0)
                if currentDirection.Z ~= 0 then moveVector = moveVector + (camCFrame.LookVector * -currentDirection.Z) end
                if currentDirection.X ~= 0 then moveVector = moveVector + (camCFrame.RightVector * currentDirection.X) end
                if currentDirection.Y ~= 0 then moveVector = moveVector + Vector3.new(0, currentDirection.Y, 0) end

                if moveVector.Magnitude > 0 then
                    pcall(function()
                        ball.AssemblyLinearVelocity = moveVector.Unit * (currentSpeed * 25)
                    end)
                end
            end
        else
            if cameraLocked and character and character:FindFirstChild("Humanoid") then
                cameraLocked = false
                Camera.CameraSubject = character.Humanoid
            end
        end
    end
end)

local function createDriveButton(text, pos, dirVec)
    local btn = Instance.new("TextButton")
